@page
@model WebAppComp3011.Pages.SetupModel
@{
    ViewData["Title"] = "Set Up Your Preferences";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Hey...sooo, what's your type? ;)</h1>
            <p class="lead">So we know what scents to recommend </p>

            <!-- Search Section -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Search &amp; Add Preferences</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">Search for brands, accords, or fragrance names you enjoy, then save them as preferences.</p>

                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <label for="SearchQuery" class="form-label">I like....</label>
                                <input type="text" class="form-control" id="SearchQuery" placeholder="e.g. Chanel, woody, vanilla..." required>
                            </div>
                            <div class="col-md-4">
                                <label for="SearchType" class="form-label">Preference Type</label>
                                <select class="form-select" id="SearchType">
                                    <option value="brand">Brand</option>
                                    <option value="accord">Accord</option>
                                    <option value="name">Name</option>
                                </select>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" id="SearchButton" class="btn btn-primary w-100">Search</button>
                            </div>
                        </div>
                    </div>

                    <div id="SearchResultsContainer"></div>
                </div>
            </div>

            <!-- Complete Setup Section -->
            <div class="card">
                <div class="card-body">
                    <p class="text-muted">
                        You can add more preferences now or skip this step (you can always come back and update it!)
                    </p>
                    <div class="d-flex gap-2">
                        <form method="post" asp-page-handler="CompleteSetup">
                            <button type="submit" class="btn btn-success">
                                Complete Setup & Continue
                            </button>
                        </form>
                        <form method="post" asp-page-handler="SkipSetup">
                            <button type="submit" class="btn btn-secondary">
                                Skip for Now
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        document.getElementById('SearchButton').addEventListener('click', async function() {
            const searchQuery = document.getElementById('SearchQuery').value.trim();
            const searchType = document.getElementById('SearchType').value;
            const resultsContainer = document.getElementById('SearchResultsContainer');
            const token = getAntiForgeryToken();

            if (!searchQuery) {
                resultsContainer.innerHTML = '<div class="alert alert-warning">Please enter a search query.</div>';
                return;
            }

            try {
                const response = await fetch(`/Setup?handler=Search`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        searchQuery: searchQuery,
                        searchType: searchType
                    })
                });

                if (!response.ok) {
                    resultsContainer.innerHTML = `<div class="alert alert-danger">Search failed with status ${response.status}.</div>`;
                    return;
                }

                const fragrances = await response.json();

                if (fragrances.length === 0) {
                    resultsContainer.innerHTML = '<div class="alert alert-info">No fragrances found matching your search. Try a different query or search type.</div>';
                    return;
                }

                let html = `<div class="search-results mt-4"><h5>Search Results (${fragrances.length} found)</h5>`;

                // Show a quick-save button for the search term itself
                html += `
                    <div class="alert alert-success d-flex justify-content-between align-items-center mb-3">
                        <span>Save <strong>"${searchQuery}"</strong> as a <strong>${searchType}</strong> preference?</span>
                        <button type="button" class="btn btn-sm btn-success" onclick="savePreference('${searchQuery.replace(/'/g, "\\'")}', '${searchType}', this)">
                            Save Preference
                        </button>
                    </div>
                `;

                html += `<div class="row">`;
                fragrances.forEach(fragrance => {
                    const rating = fragrance.rating > 0 ? `<br><strong>Rating:</strong> ${fragrance.rating.toFixed(1)} / 10` : '';
                    html += `
                        <div class="col-md-6 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h6 class="card-title">${fragrance.fragName}</h6>
                                    <p class="card-text">
                                        <small>
                                            <strong>Brand:</strong> ${fragrance.brand}<br>
                                            <strong>Gender:</strong> ${fragrance.gender}<br>
                                            <strong>Year:</strong> ${fragrance.year}${rating}
                                        </small>
                                    </p>
                                </div>
                            </div>
                        </div>
                    `;
                });

                html += `</div></div>`;
                resultsContainer.innerHTML = html;
            } catch (error) {
                resultsContainer.innerHTML = `<div class="alert alert-danger">An error occurred: ${error.message}</div>`;
                console.error('Search error:', error);
            }
        });

        async function savePreference(prefVal, prefType, btn) {
            const token = getAntiForgeryToken();
            btn.disabled = true;
            btn.textContent = 'Saving...';

            try {
                const response = await fetch(`/Setup?handler=AddPreference`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `prefVal=${encodeURIComponent(prefVal)}&prefType=${encodeURIComponent(prefType)}`,
                    redirect: 'manual'
                });

                if (response.ok || response.type === 'opaqueredirect') {
                    btn.textContent = 'Saved!';
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-outline-success');
                } else {
                    btn.textContent = 'Failed - try again';
                    btn.disabled = false;
                }
            } catch (error) {
                console.error('Save preference error:', error);
                btn.textContent = 'Error - try again';
                btn.disabled = false;
            }
        }

        document.getElementById('SearchQuery').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                document.getElementById('SearchButton').click();
            }
        });
    </script>
}