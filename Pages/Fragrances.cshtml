@page
@model WebAppComp3011.Pages.FragrancesModel
@{
    ViewData["Title"] = "Find Fragrances";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Find Fragrances</h1>
            <p class="lead">Search for fragrances by name, brand, accord, or notes and add them to your cabinet.</p>

            <!-- Search Section -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Search for Fragrances</h5>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    }

                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <label for="SearchQuery" class="form-label"> I want ....</label>
                                <input type="text" class="form-control" id="SearchQuery" placeholder="Enter fragrance name, brand, etc." required>
                            </div>
                            <div class="col-md-4">
                                <label for="SearchType" class="form-label">Search By</label>
                                <select class="form-select" id="SearchType">
                                    <option value="name">Name</option>
                                    <option value="brand">Brand</option>
                                    <option value="accord">Accord</option>
                                    <option value="notes">Notes</option>
                                </select>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" id="SearchButton" class="btn btn-primary w-100">Search</button>
                            </div>
                        </div>
                    </div>

                    <div id="SearchResultsContainer"></div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        document.getElementById('SearchButton').addEventListener('click', async function() {
            const searchQuery = document.getElementById('SearchQuery').value.trim();
            const searchType = document.getElementById('SearchType').value;
            const resultsContainer = document.getElementById('SearchResultsContainer');
            const token = getAntiForgeryToken();

            if (!searchQuery) {
                resultsContainer.innerHTML = '<div class="alert alert-warning">Please enter a search query.</div>';
                return;
            }

            try {
                const response = await fetch(`/Fragrances?handler=Search`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        searchQuery: searchQuery,
                        searchType: searchType
                    })
                });

                if (!response.ok) {
                    resultsContainer.innerHTML = `<div class="alert alert-danger">Search failed with status ${response.status}.</div>`;
                    return;
                }

                const fragrances = await response.json();

                if (fragrances.length === 0) {
                    resultsContainer.innerHTML = '<div class="alert alert-info">No fragrances found matching your search. Try a different query or search type.</div>';
                    return;
                }

                let html = `<div class="search-results mt-4"><h5>Search Results (${fragrances.length} found)</h5><div class="row">`;

                fragrances.forEach(fragrance => {
                    const rating = fragrance.rating > 0 ? `<br><strong>Rating:</strong> ${fragrance.rating.toFixed(1)} / 10` : '';
                    html += `
                        <div class="col-md-6 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h6 class="card-title">${fragrance.fragName}</h6>
                                    <p class="card-text">
                                        <small>
                                            <strong>Brand:</strong> ${fragrance.brand}<br>
                                            <strong>Gender:</strong> ${fragrance.gender}<br>
                                            <strong>Year:</strong> ${fragrance.year}${rating}
                                        </small>
                                    </p>
                                </div>
                                <div class="card-footer bg-light">
                                    <button type="button" class="btn btn-sm btn-cabinet w-100" onclick="addToCabinet(${fragrance.id}, this)">
                                        <i class="bi bi-plus-circle"></i> Add to Cabinet
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                });

                html += `</div></div>`;
                resultsContainer.innerHTML = html;
            } catch (error) {
                resultsContainer.innerHTML = `<div class="alert alert-danger">An error occurred: ${error.message}</div>`;
                console.error('Search error:', error);
            }
        });

        async function addToCabinet(fragranceId, btn) {
            const token = getAntiForgeryToken();
            const cardFooter = btn.closest('.card-footer');

            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Adding...';

            try {
                const response = await fetch(`/Fragrances?handler=AddToCabinet`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `fragranceId=${fragranceId}`,
                    redirect: 'manual'
                });

                if (response.ok || response.type === 'opaqueredirect') {
                    cardFooter.innerHTML = '<div class="alert alert-warning mb-0 py-1 text-center"><i class="bi bi-check-circle"></i> Successfully added</div>';
                } else {
                    cardFooter.innerHTML = '<div class="alert alert-danger mb-0 py-1 text-center">Failed to add. Please try again.</div>';
                }
            } catch (error) {
                cardFooter.innerHTML = '<div class="alert alert-danger mb-0 py-1 text-center">An error occurred. Please try again.</div>';
                console.error('Add to cabinet error:', error);
            }
        }

        document.getElementById('SearchQuery').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                document.getElementById('SearchButton').click();
            }
        });
    </script>
}
