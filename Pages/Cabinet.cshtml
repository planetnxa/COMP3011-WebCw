@page
@model WebAppComp3011.Pages.CabinetModel
@{
    ViewData["Title"] = "My Cabinet";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-10 offset-md-1">
            <h1>My Cabinet</h1>
            <p class="lead">Your personal fragrance collection and preferences.</p>

            <div class="mb-4">
                <a asp-page="/Recommend" class="btn btn-primary">Get Recommendations</a>
            </div>

            <!-- Preferences Section -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">My Preferences</h5>
                </div>
                <div class="card-body">
                    @if (Model.Preferences == null || Model.Preferences.Count == 0)
                    {
                        <div class="alert alert-info mb-0">
                            You haven't set any preferences yet. <a asp-page="/Setup">Set up your preferences</a> to get personalized recommendations.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Value</th>
                                        <th>Type</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pref in Model.Preferences)
                                    {
                                        <tr>
                                            <td>@pref.PrefVal</td>
                                            <td>
                                                <span class="badge bg-secondary">@pref.PrefType</span>
                                            </td>
                                            <td>
                                                <form method="post" asp-page-handler="EditPreference" class="d-inline">
                                                    <input type="hidden" name="prefId" value="@pref.Id" />
                                                    <input type="hidden" name="prefType" value="@pref.PrefType" />
                                                    <input type="text" name="prefVal" value="@pref.PrefVal" class="form-control form-control-sm d-inline" style="width: 120px; display: inline-block !important;" />
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
                                                </form>
                                                <form method="post" asp-page-handler="DeletePreference" class="d-inline">
                                                    <input type="hidden" name="prefId" value="@pref.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <!-- Cabinet Section -->
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">My Fragrances</h5>
                </div>
                <div class="card-body">
                    @if (Model.CabinetItems == null || Model.CabinetItems.Count == 0)
                    {
                        <div class="alert alert-info mb-0">Your cabinet is empty. Head to <a asp-page="/Recommend">Recommendations</a> to discover fragrances!</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Name</th>
                                        <th>Brand</th>
                                        <th>Gender</th>
                                        <th>Rating</th>
                                        <th>Year</th>
                                        <th>Accords</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var (entry, frag) in Model.CabinetItems)
                                    {
                                        <tr>
                                            <td>@frag.FragName</td>
                                            <td>@frag.Brand</td>
                                            <td>@frag.Gender</td>
                                            <td>@(frag.Rating > 0 ? frag.Rating.ToString("0.0") : "—")</td>
                                            <td>@(string.IsNullOrEmpty(frag.Year) ? "—" : frag.Year)</td>
                                            <td>@(frag.Accords != null && frag.Accords.Any() ? string.Join(", ", frag.Accords) : "—")</td>
                                            <td>
                                                <form method="post" asp-page-handler="Remove">
                                                    <input type="hidden" name="cabinetId" value="@entry.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
