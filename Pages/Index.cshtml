@page
@model WebAppComp3011.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="bg-landing">
@if (Model.IsLoggedIn)
{
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <h1 class="fade-in-up">Welcome back, @Model.DisplayName</h1>
                <p class="lead text-muted">Let's get you some new scents'</p>
                <div class="row mt-4">
                    <div class="col-md-4 mb-3 fade-in-up" style="animation-delay: 0.1s;">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <h5 class="card-title">Find Fragrances</h5>
                                <p class="card-text">Search and discover new perfumes to add to your cabinet.</p>
                                <a asp-page="/Fragrances" class="btn btn-primary">Browse</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3 fade-in-up" style="animation-delay: 0.25s;">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <h5 class="card-title">Recommendations</h5>
                                <p class="card-text">Get personalised fragrance picks based on your preferences.</p>
                                <a asp-page="/Recommend" class="btn btn-primary">Discover</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3 fade-in-up" style="animation-delay: 0.4s;">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <h5 class="card-title">My Cabinet</h5>
                                <p class="card-text">View your collection and manage your preferences.</p>
                                <a asp-page="/Cabinet" class="btn btn-primary">Open</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="landing-hero fade-in-up"></div>
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="landing-cta text-center fade-in-up" style="animation-delay: 0.2s;">
                    <h1 class="display-3 fw-bold">Chez D'Arome</h1>
                    <p class="text-white-50 mb-4">Your personal scent space.</p>
                    <a asp-page="/Login" class="btn btn-primary btn-lg me-2">Log In</a>
                    <a asp-page="/Register" class="btn btn-outline-light btn-lg">Create an Account</a>
                </div>
            </div>
        </div>
    </div>
}
</div>

