@page
@model WebAppComp3011.Pages.RecommendModel
@{
    ViewData["Title"] = "Recommended For You";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-10 offset-md-1">
            <h1>Recommended For You</h1>

            @if (Model.UserPreferences.Count > 0)
            {
                <p class="lead">Based on your preferences, here are 3 fragrances picked for you!</p>
                <div class="mb-3">
                    <small class="text-muted">
                        <strong>Your preferences:</strong>
                        @string.Join(" · ", Model.UserPreferences.Select(p => $"{p.PrefVal} ({p.PrefType})"))
                    </small>
                </div>
            }
            else
            {
                <p class="lead">You haven't set any preferences yet — here are 3 random picks. <a asp-page="/Setup">Set up preferences</a> for personalized recommendations!</p>
            }

            <div class="d-flex gap-2 mb-4">
                <a asp-page="/Recommend" class="btn btn-primary">Refresh Recommendations</a>
                <a asp-page="/Cabinet" class="btn btn-outline-secondary">View My Cabinet</a>
            </div>

            @Html.AntiForgeryToken()

            @if (Model.Recommendations == null || Model.Recommendations.Count == 0)
            {
                <div class="alert alert-info">No recommendations available right now. Try refreshing.</div>
            }
            else
            {
                <div class="row">
                    @foreach (var frag in Model.Recommendations)
                    {
                        <div class="col-md-4 mb-4 fade-in-up">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">@frag.FragName</h5>
                                    <p class="card-text">
                                        <strong>Brand:</strong> @frag.Brand<br />
                                        <strong>Gender:</strong> @frag.Gender<br />
                                        @if (frag.Rating > 0)
                                        {
                                            <strong>Rating:</strong> @frag.Rating.ToString("0.0") @: / 10<br />
                                        }
                                        @if (!string.IsNullOrEmpty(frag.Year))
                                        {
                                            <strong>Year:</strong> @frag.Year<br />
                                        }
                                        @if (frag.Accords != null && frag.Accords.Any())
                                        {
                                            <strong>Accords:</strong> @string.Join(", ", frag.Accords)<br />
                                        }
                                    </p>
                                </div>
                                <div class="card-footer">
                                    <button type="button" class="btn btn-cabinet w-100" onclick="addToCabinet(@frag.Id, this)">Add to Cabinet</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        async function addToCabinet(perfumeId, btn) {
            const token = getAntiForgeryToken();
            const cardFooter = btn.closest('.card-footer');

            btn.disabled = true;
            btn.innerHTML = 'Adding...';

            try {
                const response = await fetch(`/Recommend?handler=AddToCabinet`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `perfumeId=${perfumeId}`,
                    redirect: 'manual'
                });

                if (response.ok || response.type === 'opaqueredirect') {
                    cardFooter.innerHTML = '<div class="alert alert-warning mb-0 py-1 text-center"><i class="bi bi-check-circle"></i> Added!</div>';
                } else {
                    cardFooter.innerHTML = '<div class="alert alert-danger mb-0 py-1 text-center">Failed to add. Please try again.</div>';
                }
            } catch (error) {
                cardFooter.innerHTML = '<div class="alert alert-danger mb-0 py-1 text-center">An error occurred. Please try again.</div>';
                console.error('Add to cabinet error:', error);
            }
        }
    </script>
}
