@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<div class="mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h2>Welcome to D'Arome Fragrance App</h2>
                </div>
                <div class="card-body">
                    <p class="lead">This is your fragrance and user management platform.</p>
                    <ul>
                        <li>Browse fragrances</li>
                        <li>Register and login</li>
                        <li>Manage your user profile and cabinet</li>
                    </ul>
                    <hr>
                    <a class="btn btn-success" href="/Login">Login/Register</a>
                    <a class="btn btn-info" href="/Fragrances">Browse Fragrances</a>
                </div>
            </div>
        </div>
    </div>
</div>
